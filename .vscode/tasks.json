            "problemMatcher": "$msCompile"
        },
        // Windows export templates (dev)
        {
            "label": "win64_export_dev",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "scons",
            "args": [
