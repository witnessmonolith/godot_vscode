            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "scons",
            "args": [
                "--clean",
                "target=template_debug",
                "arch=x86_64",
                "platform=windows",
                "dev_build=yes",
                "separate_debug_symbols=yes",
                // "custom_modules=../modules"
            ],
            "problemMatcher": "$msCompile"
        },
        // Windows editor (release)
        {
            "label": "win64_release",
            "group": "build",
            "type": "shell",
            "command": "scons",
            "args": [
                "target=editor",
                "arch=x86_64",
                "platform=windows",
                "production=yes",
                "debug_symbols=yes",
                "separate_debug_symbols=yes",
                // "custom_modules=../modules"
            ],
            "problemMatcher": "$msCompile"
        },
        // Clean Windows editor (release)
        {
            "label": "clean_win64_release",
            "group": "build",
            "type": "shell",
            "command": "scons",
            "args": [
                "--clean",
                "target=editor",
                "arch=x86_64",
                "platform=windows",
                "production=yes",
                "debug_symbols=yes",
                "separate_debug_symbols=yes",
                // "custom_modules=../modules"
            ],
            "problemMatcher": "$msCompile"
        },
        // Windows export templates (release)
        {
            "label": "win64_export_release",
            "group": "build",
            "type": "shell",
            "command": "scons",
            "args": [
                "target=template_release",
                "arch=x86_64",
                "platform=windows",
                "production=yes",
                "debug_symbols=yes",
                "separate_debug_symbols=yes",
                // "custom_modules=../modules"
            ],
            "problemMatcher": "$msCompile"
        },
        // Clean Windows export templates (release)
        {
            "label": "win64_export_release",
            "group": "build",
            "type": "shell",
            "command": "scons",
            "args": [
                "--clean",
                "target=template_release",
                "arch=x86_64",
                "platform=windows",
                "production=yes",
                "debug_symbols=yes",
                "separate_debug_symbols=yes",
                // "custom_modules=../modules"
            ],
            "problemMatcher": "$msCompile"
        },
    ]
}