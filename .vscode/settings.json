{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        ".github": true,
        ".sconf_temp": true,
        "bin": true,
        "doc": true,
        "tests": true,
        "misc": true,
        "**/*.png": true,
        "**/*.svg": true,
        "**/*.obj": true,
        "**/*.dll": true,
        "**/*.lib": true,
        "**/*.a": true,
        "**/*.so": true,
        "**/*.pdb": true,
        "**/*.exe": true,
        "**/*.yml": true,
        "**/*.txt": true,
        "**/*.scons_*": true,
        "**/*.scons*": true,
    },
    "dotnet.defaultSolution": "disable"
}